prisma:query SELECT "public"."Condominio"."id", "public"."Condominio"."nome", "public"."Condominio"."endereco", "public"."Condominio"."cnpj", "public"."Condominio"."telefone", "public"."Condominio"."email", "public"."Condominio"."logo", "public"."Condominio"."ativo", "public"."Condominio"."cidade", "public"."Condominio"."estado", "public"."Condominio"."cep", "public"."Condominio"."tipoEdificacao"::text, "public"."Condominio"."blocos", "public"."Condominio"."unidades", "public"."Condominio"."pavimentos", "public"."Condominio"."mandatoInicio", "public"."Condominio"."mandatoFim", "public"."Condominio"."seguroPossui", "public"."Condominio"."seguroSeguradora", "public"."Condominio"."seguroApolice", "public"."Condominio"."seguroInicio", "public"."Condominio"."seguroVencimento", "public"."Condominio"."seguroDocumento", "public"."Condominio"."portalConfig", "public"."Condominio"."createdAt", "public"."Condominio"."updatedAt", COALESCE("aggr_selection_0_User"."_aggr_count_users", 0) AS "_aggr_count_users", COALESCE("aggr_selection_1_Manutencao"."_aggr_count_manutencoes", 0) AS "_aggr_count_manutencoes", COALESCE("aggr_selection_2_Documento"."_aggr_count_documentos", 0) AS "_aggr_count_documentos", COALESCE("aggr_selection_3_Banner"."_aggr_count_banners", 0) AS "_aggr_count_banners", COALESCE("aggr_selection_4_PlanoManutencaoItem"."_aggr_count_planoManutencao", 0) AS "_aggr_count_planoManutencao" FROM "public"."Condominio" LEFT JOIN (SELECT "public"."User"."condominioId", COUNT(*) AS "_aggr_count_users" FROM "public"."User" WHERE 1=1 GROUP BY "public"."User"."condominioId") AS "aggr_selection_0_User" ON ("public"."Condominio"."id" = "aggr_selection_0_User"."condominioId") LEFT JOIN (SELECT "public"."Manutencao"."condominioId", COUNT(*) AS "_aggr_count_manutencoes" FROM "public"."Manutencao" WHERE 1=1 GROUP BY "public"."Manutencao"."condominioId") AS "aggr_selection_1_Manutencao" ON ("public"."Condominio"."id" = "aggr_selection_1_Manutencao"."condominioId") LEFT JOIN (SELECT "public"."Documento"."condominioId", COUNT(*) AS "_aggr_count_documentos" FROM "public"."Documento" WHERE 1=1 GROUP BY "public"."Documento"."condominioId") AS "aggr_selection_2_Documento" ON ("public"."Condominio"."id" = "aggr_selection_2_Documento"."condominioId") LEFT JOIN (SELECT "public"."Banner"."condominioId", COUNT(*) AS "_aggr_count_banners" FROM "public"."Banner" WHERE 1=1 GROUP BY "public"."Banner"."condominioId") AS "aggr_selection_3_Banner" ON ("public"."Condominio"."id" = "aggr_selection_3_Banner"."condominioId") LEFT JOIN (SELECT "public"."PlanoManutencaoItem"."condominioId", COUNT(*) AS "_aggr_count_planoManutencao" FROM "public"."PlanoManutencaoItem" WHERE 1=1 GROUP BY "public"."PlanoManutencaoItem"."condominioId") AS "aggr_selection_4_PlanoManutencaoItem" ON ("public"."Condominio"."id" = "aggr_selection_4_PlanoManutencaoItem"."condominioId") WHERE (("public"."Condominio"."id") IN (SELECT "t1"."condominioId" FROM "public"."User" AS "t1" WHERE ("t1"."id" = $1 AND "t1"."condominioId" IS NOT NULL)) OR ("public"."Condominio"."id") IN (SELECT "t2"."condominioId" FROM "public"."CondominioAcesso" AS "t2" WHERE ("t2"."userId" = $2 AND "t2"."condominioId" IS NOT NULL))) ORDER BY "public"."Condominio"."createdAt" DESC OFFSET $3
