model Funcionario {
  id           Int       @id @default(autoincrement())
  nome         String
  sobrenome    String
  email        String    @unique
  telefone     String?
  dataContratacao DateTime
  registrosPonto RegistroPonto[]
  avisos       AvisoFuncionario[]
  treinamentos TreinamentoFuncionario[]
  solicitacoes SolicitacaoFuncionario[]
}

model ConfigPainelFuncionario {
  id             Int      @id @default(autoincrement())
  funcionarioId  Int      @unique
  notificacaoEmail Boolean @default(false)
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
}

model RegistroPonto {
  id             Int      @id @default(autoincrement())
  funcionarioId  Int
  dataHoraEntrada DateTime
  dataHoraSaida  DateTime
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
}

model Aviso {
  id           Int      @id @default(autoincrement())
  titulo       String
  conteudo     String
  dataCriacao  DateTime @default(now())
  avisos       AvisoFuncionario[]
}

model AvisoFuncionario {
  id           Int      @id @default(autoincrement())
  avisoId      Int
  funcionarioId Int
  visto        Boolean   @default(false)
  aviso        Aviso     @relation(fields: [avisoId], references: [id])
  funcionario  Funcionario @relation(fields: [funcionarioId], references: [id])
}

model Treinamento {
  id           Int      @id @default(autoincrement())
  titulo       String
  descricao    String
  dataInicio   DateTime
  dataFim      DateTime
  treinamentos Funcionario[]
}

model TreinamentoFuncionario {
  id             Int         @id @default(autoincrement())
  funcionarioId  Int
  treinamentoId  Int
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
  treinamento    Treinamento @relation(fields: [treinamentoId], references: [id])
}

model SolicitacaoFuncionario {
  id           Int      @id @default(autoincrement())
  funcionarioId Int
  tipoSolicitacao String
  descricao    String
  dataSolicitacao DateTime @default(now())
  funcionario  Funcionario @relation(fields: [funcionarioId], references: [id])
}

model ListaCompras {
  id             Int      @id @default(autoincrement())
  funcionarioId  Int
  item           String
  quantidade     Int
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
}